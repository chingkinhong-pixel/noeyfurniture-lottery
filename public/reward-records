<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NOEY - 中奖流水库</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #FAFAFA; font-family: -apple-system, sans-serif; color: #1A1A1A; }
        .nav-link { color: #999; padding-bottom: 12px; font-size: 14px; letter-spacing: 0.1em; transition: all 0.3s; border-bottom: 2px solid transparent; }
        .nav-link:hover { color: #1A1A1A; }
        .nav-link.active { color: #1A1A1A; font-weight: 600; border-bottom: 2px solid #1A1A1A; }
        .table-header { font-size: 10px; text-transform: uppercase; letter-spacing: 0.15em; color: #999; border-bottom: 1px solid #EBEBEB; padding-bottom: 8px; }
        .table-cell { font-size: 12px; padding: 16px 0; border-bottom: 1px solid #F5F5F5; }
        
        /* NOEY 极简状态颜色体系 */
        .status-未领取 { color: #991b1b; }
        .status-未联系 { color: #b45309; }
        .status-已通知 { color: #1e40af; }
        .status-已领取 { color: #166534; font-weight: bold;}
        .status-已完成 { color: #9ca3af; text-decoration: line-through; }
    </style>
</head>
<body class="min-h-screen">
    
    <header class="bg-white border-b border-[#EBEBEB] sticky top-0 z-50">
        <div class="max-w-[1000px] mx-auto px-6 pt-6 flex justify-between items-end">
            <div>
                <h1 class="text-xl font-bold tracking-widest mb-6">NOEY REWARDS</h1>
                <nav class="flex space-x-8">
                    <a href="admin.html" class="nav-link">基础设置与资产</a>
                    <a href="customer-management.html" class="nav-link">客户跟进 CRM</a>
                    <a href="reward-records.html" class="nav-link active">中奖流水库</a>
                </nav>
            </div>
            <button onclick="logout()" class="mb-6 text-xs text-gray-400 hover:text-black tracking-widest transition">退出</button>
        </div>
    </header>

    <div class="max-w-[1000px] mx-auto px-6 py-8">
        <div class="bg-white border border-[#EBEBEB] rounded-lg p-6 shadow-sm">
            <h2 class="text-sm font-bold tracking-widest uppercase mb-6">独立中奖流水核销单</h2>
            
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr>
                        <th class="table-header w-32">用户资料</th>
                        <th class="table-header w-32">中奖时间</th>
                        <th class="table-header">所获礼遇</th>
                        <th class="table-header w-32">发放状态核销</th>
                    </tr>
                </thead>
                <tbody id="recordsTableBody">
                    <!-- JS 渲染区 -->
                </tbody>
            </table>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('token');
        if (!token) window.location.href = '/login.html';
        const headers = { 'Authorization': token, 'Content-Type': 'application/json' };
        
        const claimStatusOptions = ['未领取', '未联系', '已通知', '已领取', '已完成'];

        async function loadRecords() {
            try {
                const res = await fetch('/api/admin/rewards', { headers });
                if (res.status === 403) return logout();
                const records = await res.json();
                renderRecords(records);
            } catch(e) { console.error(e); }
        }

        function renderRecords(records) {
            document.getElementById('recordsTableBody').innerHTML = records.map(r => `
                <tr>
                    <td class="table-cell">
                        <div class="font-bold text-[#1A1A1A]">${r.userName}</div>
                        <div class="text-xs text-gray-500 font-mono mt-1">${r.phone}</div>
                    </td>
                    <td class="table-cell text-xs text-gray-500">${r.winTime}</td>
                    <td class="table-cell">
                        <div class="text-[10px] text-gray-400 tracking-widest mb-1 uppercase">${r.prizeType}</div>
                        <div class="font-bold text-[#8C6A4F] text-sm">${r.prizeName}</div>
                    </td>
                    <td class="table-cell">
                        <select onchange="updateRecordStatus('${r._id}', this.value)" class="text-xs font-bold border border-gray-200 rounded p-1 focus:outline-none focus:border-black bg-transparent status-${r.claimStatus}">
                            ${claimStatusOptions.map(opt => `<option value="${opt}" ${r.claimStatus === opt ? 'selected' : ''} class="text-black">${opt}</option>`).join('')}
                        </select>
                    </td>
                </tr>
            `).join('');
        }

        async function updateRecordStatus(id, status) {
            try {
                await fetch(`/api/admin/rewards/${id}`, { method: 'PUT', headers, body: JSON.stringify({ claimStatus: status }) });
                loadRecords(); // 刷新以更新颜色
            } catch(e) { alert('状态更新失败'); }
        }

        function logout() { localStorage.removeItem('token'); window.location.href = '/login.html'; }
        
        loadRecords();
    </script>
</body>
</html>
